<entity-eca-rules xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/entity-eca-3.xsd">

    <!--
        Validate the mutually exclusive configuration reference on DeviceRule.

        A DeviceRule must operate on exactly one configuration reference:
        - deviceConfigId for an atomic reusable DeviceConfig
        - deviceConfigSetId for a static composed DeviceConfigSet

        This is intentionally an Entity ECA because it protects the data invariant
        regardless of which screen, service, import, loader, API, or integration
        creates or updates DeviceRule rows.
    -->
    <eeca id="DeviceRuleMutuallyExclConfig" entity="moqui.device.DeviceRule"
        on-create="true" on-update="true" run-before="true" run-on-error="false" get-entire-entity="true">
    <condition><expression>(deviceConfigId &amp;&amp; deviceConfigSetId) || (!deviceConfigId &amp;&amp; !deviceConfigSetId)</expression></condition>
    <actions><return error="true" message="A DeviceRule must operate on exactly one configuration reference: deviceConfigId or deviceConfigSetId."/></actions>
</eeca>
</entity-eca-rules>