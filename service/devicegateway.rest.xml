<?xml version="1.0" encoding="UTF-8"?>
<resource xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/rest-api-3.xsd"
        name="deviceGateway"
        displayName="Moqui Device Gateway REST API"
        version="1.0.0"
        description="REST endpoints used by moqui-device-gateway to callback into Moqui."
        require-authentication="anonymous-all">

    <resource name="requests" require-authentication="anonymous-all">
        <resource name="callback">
            <method type="post" require-authentication="anonymous-all">
                <service name="moqui.device.DeviceServices.receive#GatewayRequestCallback"/>
            </method>
        </resource>
    </resource>
</resource>
