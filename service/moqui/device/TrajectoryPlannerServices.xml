<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.xsd">

    <!-- ========== Trajectory Planner ========== -->

    <service verb="run" noun="RobotArmTrajectoryPlanner">
        <description>
            Run a 6-DOF robot trajectory planner using a DJL ONNX MLP model.

            The model accepts [q_start(6) || q_goal(6)] (12 inputs) and produces
            N_WAYPOINTS x 6 joint angles (flat output).

            Persists results to:
                Vector / VectorComponent        — per-waypoint joint positions + q_start/q_goal
                ApproximatedFunction            — parent function container
                ParametricPath                  — path-level metadata
                Trajectory                      — time-tagged motion
                ApproximatedFunctionSample      — one sample per waypoint
                ParametricPathPoint             — path point per sample
                TrajectoryPoint                 — time offset per sample
                MathModelRun                    — execution record
                MathModelPerf                   — latency / throughput counters
                MathModelData                   — links model to trajectory + input vectors

            The ONNX model file is resolved from MathModelDefContent.contentLocation
            (e.g. component://moqui-device/data/ml/trajectory_planner.onnx).
            Run script/train_robot_arm_trajectory_planner.py once to produce it.
        </description>
        <in-parameters>
            <parameter name="mathModelId" required="true">
                <description>ID of the MathModel instance to use for inference.</description>
            </parameter>
            <parameter name="startConfig" type="List" required="true">
                <description>6 joint angles in radians — start configuration.</description>
            </parameter>
            <parameter name="goalConfig" type="List" required="true">
                <description>6 joint angles in radians — goal configuration.</description>
            </parameter>
            <parameter name="trajectoryName" type="String" default-value=""/>
        </in-parameters>
        <out-parameters>
            <parameter name="mathModelRunId"/>
            <parameter name="approximatedFunctionId"/>
            <parameter name="mathModelPerfId"/>
        </out-parameters>
        <actions>
            <entity-find-one entity-name="moqui.math.MathModel" value-field="mathModel">
                <field-map field-name="mathModelId"/>
            </entity-find-one>
            <if condition="!mathModel">
                <return error="true" message="MathModel ${mathModelId} not found"/>
            </if>

            <entity-find-one entity-name="moqui.math.MathModelDefContent" value-field="onnxContent">
                <field-map field-name="mathModelDefId" from="mathModel.mathModelDefId"/>
                <field-map field-name="contentTypeEnumId" value="MmCntOnnx"/>
            </entity-find-one>
            <if condition="!onnxContent">
                <return error="true" message="No ONNX content for MathModelDef ${mathModel.mathModelDefId}"/>
            </if>

            <script><![CDATA[
                import groovy.json.JsonOutput
                import org.moqui.device.TrajectoryGenerator

                startConfigList = TrajectoryGenerator.normalizeJointConfig(startConfig, "startConfig")
                goalConfigList = TrajectoryGenerator.normalizeJointConfig(goalConfig, "goalConfig")
                mathModelRunParameters = JsonOutput.toJson([startConfig: startConfigList, goalConfig: goalConfigList])
                trajectoryLabel = trajectoryName ?: null
            ]]></script>

            <set field="mathModelRunFields" from="[mathModelId: mathModelId, startTime: ec.user.nowTimestamp,
                parameters: mathModelRunParameters, hasError: 'N']"/>
            <entity-make-value entity-name="moqui.math.MathModelRun" value-field="runVal" map="mathModelRunFields"/>
            <script><![CDATA[
                t0 = System.currentTimeMillis()
                runVal.setSequencedIdPrimary()
            ]]></script>
            <entity-create value-field="runVal"/>
            <set field="runId" from="runVal.mathModelRunId"/>

            <script><![CDATA[
                import groovy.json.JsonOutput
                import org.moqui.context.ExecutionContext
                import org.moqui.device.TrajectoryGenerator

                ExecutionContext ec = context.ec

                try {
                    Map inference = TrajectoryGenerator.runInference(ec, onnxContent.contentLocation as String,
                        startConfigList, goalConfigList)
                    waypoints = inference.waypoints
                    waypointCount = inference.waypointCount
                    inferenceLatencyMs = inference.inferenceLatencyMs ?: 0L
                } catch (Throwable t) {
                    long elapsed = System.currentTimeMillis() - t0
                    def runRef = ec.entity.find("moqui.math.MathModelRun").condition("mathModelRunId", runId).one()
                    if (runRef) {
                        runRef.setAll([endDate : ec.user.nowTimestamp, runningTimeMillis: (float) elapsed,
                            hasError : 'Y', errors : t.message])
                        runRef.update()
                    }
                    throw t
                }
            ]]></script>

            <set field="trajectoryLabel" from="trajectoryLabel ?: 'AI Trajectory ' + runId"/>
            <set field="approximatedFunctionFields" from="[vectorSpaceEnumId: 'EngJointSpace6Dof', codomainTypeEnumId: 'AfctVector',
                dataStorageEnumId: 'AfdsPointTable', purposeEnumId: 'AfpRobotMotion', interpolationEnumId: 'AfiAIPath',
                name: trajectoryLabel, description: '6-DOF robot trajectory from MLP planner']"/>
            <entity-make-value entity-name="moqui.math.ApproximatedFunction" value-field="approximatedFunctionValue" map="approximatedFunctionFields"/>
            <script><![CDATA[approximatedFunctionValue.setSequencedIdPrimary()]]></script>
            <entity-create value-field="approximatedFunctionValue"/>
            <set field="approximatedFunctionId" from="approximatedFunctionValue.approximatedFunctionId"/>

            <set field="parametricPathFields" from="[approximatedFunctionId: approximatedFunctionId, profileEnumId: 'PppfTrajectoryProfile']"/>
            <entity-make-value entity-name="moqui.math.ParametricPath" value-field="parametricPathValue" map="parametricPathFields"/>
            <entity-create value-field="parametricPathValue"/>

            <set field="trajectoryFields" from="[approximatedFunctionId: approximatedFunctionId, actuationTypeEnumId: 'PtaDirect',
                actuatorTypeEnumId: 'PtactRevolute', controlMethodEnumId: 'PtcmNNControl']"/>
            <entity-make-value entity-name="moqui.math.Trajectory" value-field="trajectoryValue" map="trajectoryFields"/>
            <entity-create value-field="trajectoryValue"/>

            <set field="stepMs" from="waypointCount > 1 ? 1000.0d / (waypointCount - 1) : 0.0d"/>
            <set field="waypointIndex" from="0" type="Integer"/>
            <iterate list="waypoints" entry="waypoint">
                <set field="waypointVectorFields" from="[vectorTypeEnumId: 'VtOrdinary', purposeEnumId: 'VpPosition', dimension: 6]"/>
                <entity-make-value entity-name="moqui.math.Vector" value-field="waypointVectorValue" map="waypointVectorFields"/>
                <script><![CDATA[waypointVectorValue.setSequencedIdPrimary()]]></script>
                <entity-create value-field="waypointVectorValue"/>
                <set field="waypointVectorId" from="waypointVectorValue.vectorId"/>

                <set field="jointIndex" from="0" type="Integer"/>
                <iterate list="waypoint" entry="jointValue">
                    <set field="waypointComponentFields" from="[vectorId: waypointVectorId, dimensionIndex: jointIndex,
                        componentTypeEnumId: 'VctCanonical', realValue: jointValue]"/>
                    <entity-make-value entity-name="moqui.math.VectorComponent" value-field="waypointComponentValue" map="waypointComponentFields"/>
                    <script><![CDATA[waypointComponentValue.setSequencedIdPrimary()]]></script>
                    <entity-create value-field="waypointComponentValue"/>
                    <set field="jointIndex" from="jointIndex + 1" type="Integer"/>
                </iterate>

                <set field="sampleTypeEnumId" from="waypointIndex == 0 ? 'AfstStartPoint' : (waypointIndex == (waypointCount - 1) ? 'AfstEndPoint' : 'AfstWaypoint')"/>
                <set field="sampleFields" from="[approximatedFunctionId: approximatedFunctionId, sampleCode: 'WP' + String.format('%04d', waypointIndex),
                    sampleName: 'Waypoint ' + waypointIndex, sequenceNum: waypointIndex, sampleTypeEnumId: sampleTypeEnumId,
                    sampleVectorId: waypointVectorId]"/>
                <entity-make-value entity-name="moqui.math.ApproximatedFunctionSample" value-field="sampleValue" map="sampleFields"/>
                <script><![CDATA[sampleValue.setSequencedIdSecondary()]]></script>
                <entity-create value-field="sampleValue"/>
                <set field="sampleId" from="sampleValue.approximatedFunctionSampleId"/>

                <set field="pathPointFields" from="[approximatedFunctionId: approximatedFunctionId, approximatedFunctionSampleId: sampleId]"/>
                <entity-make-value entity-name="moqui.math.ParametricPathPoint" value-field="pathPointValue" map="pathPointFields"/>
                <entity-create value-field="pathPointValue"/>

                <set field="trajectoryPointFields" from="[approximatedFunctionId: approximatedFunctionId,
                    approximatedFunctionSampleId: sampleId, pointTimeOffsetMillis: waypointIndex * stepMs]"/>
                <entity-make-value entity-name="moqui.math.TrajectoryPoint" value-field="trajectoryPointValue" map="trajectoryPointFields"/>
                <entity-create value-field="trajectoryPointValue"/>

                <set field="waypointIndex" from="waypointIndex + 1" type="Integer"/>
            </iterate>

            <set field="inputVectorList" from="[[name: 'q_start', values: startConfigList], [name: 'q_goal', values: goalConfigList]]"/>
            <set field="inputVectorIdList" from="[]" type="NewList"/>
            <iterate list="inputVectorList" entry="inputVector">
                <set field="inputVectorFields" from="[vectorTypeEnumId: 'VtOrdinary', purposeEnumId: 'VpPosition',
                    dimension: 6, name: inputVector.name]"/>
                <entity-make-value entity-name="moqui.math.Vector" value-field="inputVectorValue" map="inputVectorFields"/>
                <script><![CDATA[inputVectorValue.setSequencedIdPrimary()]]></script>
                <entity-create value-field="inputVectorValue"/>
                <script><![CDATA[inputVectorIdList.add(inputVectorValue.vectorId)]]></script>

                <set field="jointIndex" from="0" type="Integer"/>
                <iterate list="inputVector.values" entry="jointValue">
                    <set field="inputVectorComponentFields" from="[vectorId: inputVectorValue.vectorId, dimensionIndex: jointIndex,
                        componentTypeEnumId: 'VctCanonical', realValue: jointValue]"/>
                    <entity-make-value entity-name="moqui.math.VectorComponent" value-field="inputVectorComponentValue" map="inputVectorComponentFields"/>
                    <script><![CDATA[inputVectorComponentValue.setSequencedIdPrimary()]]></script>
                    <entity-create value-field="inputVectorComponentValue"/>
                    <set field="jointIndex" from="jointIndex + 1" type="Integer"/>
                </iterate>
            </iterate>

            <set field="startVectorId" from="inputVectorIdList[0]"/>
            <set field="goalVectorId" from="inputVectorIdList[1]"/>

            <set field="outputModelDataFields" from="[mathModelId: mathModelId, dataTypeEnumId: 'MmdtApproxFunc',
                purposeEnumId: 'MmdpModelOutputs', generatedByRunId: runId, approximatedFunctionId: approximatedFunctionId,
                sequenceNum: 1]"/>
            <entity-make-value entity-name="moqui.math.MathModelData" value-field="outputModelDataValue" map="outputModelDataFields"/>
            <script><![CDATA[outputModelDataValue.setSequencedIdPrimary()]]></script>
            <entity-create value-field="outputModelDataValue"/>

            <set field="startModelDataFields" from="[mathModelId: mathModelId, dataTypeEnumId: 'MmdtVector',
                purposeEnumId: 'MmdpModelInputs', generatedByRunId: runId, vectorId: startVectorId, sequenceNum: 2]"/>
            <entity-make-value entity-name="moqui.math.MathModelData" value-field="startModelDataValue" map="startModelDataFields"/>
            <script><![CDATA[startModelDataValue.setSequencedIdPrimary()]]></script>
            <entity-create value-field="startModelDataValue"/>

            <set field="goalModelDataFields" from="[mathModelId: mathModelId, dataTypeEnumId: 'MmdtVector',
                purposeEnumId: 'MmdpModelInputs', generatedByRunId: runId, vectorId: goalVectorId, sequenceNum: 3]"/>
            <entity-make-value entity-name="moqui.math.MathModelData" value-field="goalModelDataValue" map="goalModelDataFields"/>
            <script><![CDATA[goalModelDataValue.setSequencedIdPrimary()]]></script>
            <entity-create value-field="goalModelDataValue"/>

            <script><![CDATA[
                import groovy.json.JsonOutput

                long elapsed = System.currentTimeMillis() - t0
                double totalDurationSec = elapsed > 0 ? elapsed / 1000.0d : 0.001d
                resultsJson = JsonOutput.toJson([approximatedFunctionId: approximatedFunctionId, waypointCount: waypointCount])

                def runRef = ec.entity.find("moqui.math.MathModelRun").condition("mathModelRunId", runId).one()
                runRef.setAll([endDate : ec.user.nowTimestamp, runningTimeMillis : (float) elapsed,
                    approximatedFunctionId: approximatedFunctionId, results : resultsJson])
                runRef.update()

                perfFields = [mathModelRunId: runId, totalDurationSec: totalDurationSec,
                    inferenceLatencyMs: inferenceLatencyMs as double,
                    throughputSamplesSec: (waypointCount as double) / totalDurationSec]
            ]]></script>
            <entity-make-value entity-name="moqui.math.MathModelPerf" value-field="perfValue" map="perfFields"/>
            <script><![CDATA[perfValue.setSequencedIdPrimary()]]></script>
            <entity-create value-field="perfValue"/>
            <set field="mathModelRunId" from="runId"/>
            <set field="mathModelPerfId" from="perfValue.mathModelPerfId"/>
        </actions>
    </service>
</services>
